# === PRODUCTION ENVIRONMENT ===
# Copy this file and fill in real values. NEVER commit the filled version.

# Supabase (same project as dev — it's already cloud-hosted)
SUPABASE_URL=https://sjdzmkqfsehfpptxoxca.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# AI API Keys
ANTHROPIC_API_KEY=<your-anthropic-key>
OPENROUTER_API_KEY=<your-openrouter-key>

# AI Model Config
OCR_PROVIDER=openrouter
OCR_MODEL=qwen/qwen3.5-9b
CLASSIFIER_PROVIDER=openrouter
CLASSIFIER_MODEL=deepseek/deepseek-chat-v3-0324
CLASSIFIER_MODE=scoped

# Redis (update if using external Redis like Railway/Upstash)
REDIS_URL=redis://redis:6379

# App URLs (update after deployment)
BACKEND_URL=https://<your-backend-url>
FRONTEND_URL=https://<your-vercel-url>
ENVIRONMENT=production

# Next.js (set these on Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://sjdzmkqfsehfpptxoxca.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
NEXT_PUBLIC_API_URL=https://<your-backend-url>
NEXT_PUBLIC_DISABLE_AUTH=false

# Auth MUST be disabled in production
DISABLE_AUTH=false
